{
	"name": "weldingtoolbox2",
	"version": "2.2.0",
	"private": true,
	"packageManager": "pnpm@10.26.2",
	"scripts": {
		"android": "expo run:android",
		"ios": "expo run:ios",
		"build": "pnpm recursive run build",
		"build:android": "eas build --platform android",
		"build:ios": "eas build --platform ios",
		"build:all": "eas build --platform all",
		"lint": "biome check --write .",
		"test": "pnpm lint && node --test --import tsx utils/**/*.test.ts && pnpm --filter welding-utils test",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish",
		"eas-build-post-install": "pnpm build"
	},
	"dependencies": {
		"@expo/ui": "0.2.0-canary-20260121-a63c0dd",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"babel-plugin-transform-remove-console": "^6.9.4",
		"expo": "~54.0.35",
		"expo-build-properties": "^1.0.10",
		"expo-clipboard": "~8.0.8",
		"expo-file-system": "~19.0.23",
		"expo-glass-effect": "~0.1.10",
		"expo-router": "~6.0.24",
		"expo-sharing": "~14.0.8",
		"expo-splash-screen": "~31.0.13",
		"expo-system-ui": "^6.0.9",
		"react": "19.1.0",
		"react-native": "0.86.0",
		"react-native-arkit-measurement": "workspace:*",
		"react-native-draggable-flatlist": "^4.0.3",
		"react-native-gesture-handler": "^2.30.0",
		"react-native-reanimated": "^4.2.1",
		"react-native-safe-area-context": "^5.6.2",
		"welding-utils": "workspace:*",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@babel/preset-env": "^7.29.7",
		"@babel/runtime": "^7.29.7",
		"@biomejs/biome": "2.5.1",
		"@changesets/cli": "^2.31.0",
		"@types/react": "~19.1.10",
		"expo-dev-client": "~6.0.21",
		"tsx": "^4.19.2",
		"typescript": "~5.9.3"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"listUnknownPackages": false
			}
		}
	}
}
